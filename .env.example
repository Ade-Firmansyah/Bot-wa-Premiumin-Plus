# API Configuration
# Either provide a decrypted key or use encrypted key support
API_KEY=your_api_key_here
CRYPTO_SECRET=your_crypto_secret_here
ENCRYPTED_API_KEY=your_encrypted_api_key_here

# Server Configuration
# Port for QR code HTTP server (Railway auto-assigns PORT if not set)
# Leave empty for Railway auto-detection or set to specific port for local testing
PORT=3000

# Optional: Enable debugging
DEBUG=false
LOG_LEVEL=error

# Optional provider override for payment API endpoint
PREMKU_API_BASE_URL=https://premku.com/api
# PAYMENT_API_BASE_URL=https://premku.com/api

# Note: RAILWAY_ENVIRONMENT is automatically set by Railway
# Sessions directory is automatically created and managed
